    .ship-tile.selected {
      background: rgba(6, 182, 212, .42);
      border-color: #22d3ee;
      box-shadow: 0 0 15px rgba(34, 211, 238, .5);
    }
    .ship-tile.placed { opacity: .35; cursor: not-allowed; }
    .ship-block {
      background: linear-gradient(135deg, #06b6d4, #0891b2);
      border-radius: 3px;
      box-shadow: inset 0 0 4px rgba(255,255,255,.3);
    }

    .code-digit {
      width: 52px;
      height: 64px;
      background: linear-gradient(135deg, rgba(6,182,212,.2), rgba(14,165,233,.1));
      border: 2px solid rgba(34, 211, 238, .4);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      font-weight: 800;
      font-family: 'JetBrains Mono', monospace;
      color: #22d3ee;
      text-shadow: 0 0 10px rgba(34, 211, 238, .6);
    }

    .question-card {
      background: linear-gradient(135deg, rgba(168, 85, 247, .18), rgba(236, 72, 153, .11));
      border: 1px solid rgba(168, 85, 247, .34);
    }
    .answer-btn {
      background: rgba(15, 23, 55, .64);
      border: 1px solid rgba(168, 85, 247, .25);
      color: #e4e8ff;
      padding: 14px 16px;
      border-radius: 12px;
      text-align: left;
      transition: all .2s;
      width: 100%;
    }
    .answer-btn:hover:not(:disabled) {
      background: rgba(168, 85, 247, .16);
      border-color: rgba(168, 85, 247, .65);
      transform: translateX(4px);
    }
    .answer-correct {
      background: rgba(34,197,94,.22) !important;
      border-color: #22c55e !important;
      color: #86efac !important;
    }
    .answer-wrong {
      background: rgba(239,68,68,.22) !important;
      border-color: #ef4444 !important;
      color: #fca5a5 !important;
    }

    .toast {
      position: fixed;
      top: max(16px, env(safe-area-inset-top));
      left: 50%;
      transform: translateX(-50%);
      padding: 12px 20px;
      border-radius: 12px;
      z-index: 2000;
      animation: slideDown .25s ease-out;
      backdrop-filter: blur(10px);
      max-width: 92%;
      font-weight: 700;
      box-shadow: 0 10px 35px rgba(0,0,0,.25);
    }
    .toast-success { background: rgba(34, 197, 94, .92); color: white; }
    .toast-error { background: rgba(239, 68, 68, .92); color: white; }
    .toast-info { background: rgba(34, 211, 238, .92); color: #06202a; }

    .loader {
      border: 3px solid rgba(34, 211, 238, .2);
      border-top-color: #22d3ee;
      border-radius: 50%;
      width: 22px;
      height: 22px;
      animation: spin .8s linear infinite;
    }
    .tab-active {
      background: linear-gradient(135deg, rgba(6,182,212,.3), rgba(14,165,233,.2)) !important;
      border-color: #22d3ee !important;
      color: #22d3ee !important;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes hitPulse {
      0% { transform: scale(1.25); box-shadow: 0 0 40px #ef4444; }
      100% { transform: scale(1); box-shadow: 0 0 10px #ef4444; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .float-anim { animation: float 3s ease-in-out infinite; }
    @keyframes slideUp {
      from { transform: translateY(28px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    @keyframes slideDown {
      from { transform: translate(-50%, -16px); opacity: 0; }
      to { transform: translate(-50%, 0); opacity: 1; }
    }
    .slide-up { animation: slideUp .35s ease-out; }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    .turn-indicator {
      background: linear-gradient(90deg, rgba(6,182,212,.10), rgba(34,211,238,.28), rgba(6,182,212,.10));
