async function createGame() {
  if (!state.playerName.trim()) { toast('Zadej jméno hráče nebo týmu.', 'error'); return; }

  const btn = document.getElementById('btn-create-game');
  const selectedTopicIds = Array.from(document.querySelectorAll('.topic-choice:checked')).map(el => el.value);

  if (selectedTopicIds.length === 0) {
    toast('Vyber alespoň jeden okruh otázek.', 'error');
    return;
  }

  let questions = [];
  const usedQuestionKeys = new Set();
  const selectedTopicNames = [];

  try {
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<div class="loader"></div><span>Spojuji vybrané okruhy…</span>';
    }

    for (const topicId of selectedTopicIds) {
      const topic = state.allTopics.find(t => t.__backendId === topicId);
      if (!topic) throw new Error('Jeden z vybraných okruhů už neexistuje.');

      selectedTopicNames.push(topic.topicName || 'Okruh');
      const topicQuestions = normalizeQuestions(JSON.parse(topic.questionsData));

      for (const q of topicQuestions) {
        // Jednoduché odstranění duplicit podle textu otázky a správné odpovědi.
        const uniqueKey = `${q.otazka.trim().toLowerCase()}|${q.spravna_odpoved}`;
        if (!usedQuestionKeys.has(uniqueKey)) {
          usedQuestionKeys.add(uniqueKey);
          questions.push({ ...q, id: questions.length + 1 });
        }
      }
    }

    if (questions.length === 0) throw new Error('Vybrané okruhy neobsahují žádné platné otázky.');
  } catch (e) {
    toast(e.message || 'Otázky se nepodařilo připravit.', 'error');
    if (btn) {
      btn.disabled = false;
      btn.innerHTML = '<i data-lucide="rocket" class="w-5 h-5"></i><span>Vytvořit hru z vybraných okruhů</span>';
      safeIcons();
    }
    return;
  }

  let code, attempts = 0;
  do {
    code = generateGameCode();
    attempts++;
  } while (state.allGames.some(g => g.gameCode === code && g.status !== 'finished') && attempts < 100);

  const newGame = {
    type: 'game',
    gameCode: code,
    status: 'waiting',
    player1Name: state.playerName.trim(),
    player2Name: '',
    player1Board: JSON.stringify(createEmptyBoard()),
    player2Board: JSON.stringify(createEmptyBoard()),
    player1Shots: JSON.stringify(createEmptyBoard()),
    player2Shots: JSON.stringify(createEmptyBoard()),
    player1Ready: false,
    player2Ready: false,
    currentTurn: 'p1',
    questionsJson: JSON.stringify(questions),
    topicNames: selectedTopicNames.join(', '),
    currentQuestion: '',
    shotsRemaining: 0,
    winner: '',
    player1Score: 0,
    player2Score: 0,
    createdAt: new Date().toISOString(),
    lastAction: ''
  };

  if (btn) btn.innerHTML = '<div class="loader"></div><span>Vytvářím hru…</span>';
  const result = await store.create(newGame);

  if (result.isOk) {
    const created = result.record || state.allGames.find(g => g.gameCode === code) || { ...newGame, __backendId: newGame.__backendId };
    state.currentGame = created;
    state.playerRole = 'p1';
    state.questions = questions;
    state.view = 'waiting';
    resetShips();
    toast(`Hra vytvořena z ${selectedTopicIds.length} okruhů (${questions.length} otázek).`, 'success');
    render();
  } else {
    toast('Hru se nepodařilo vytvořit.', 'error');
    if (btn) {
      btn.disabled = false;
      btn.innerHTML = '<i data-lucide="rocket" class="w-5 h-5"></i><span>Vytvořit hru z vybraných okruhů</span>';
      safeIcons();
    }
  }
}

async function joinGame() {
  const code = document.getElementById('game-code-input')?.value.trim();
  if (!state.playerName.trim()) { toast('Nejdřív zadej jméno v hlavním menu.', 'error'); return; }
  if (!/^\d{4}$/.test(code)) { toast('Zadej 4místný kód.', 'error'); return; }

  const game = state.allGames.find(g => g.gameCode === code && g.status === 'waiting');
  if (!game) { toast('Hra s tímto kódem neexistuje nebo už začala.', 'error'); return; }

  const updated = { ...game, player2Name: state.playerName.trim(), status: 'placing' };
  const result = await store.update(updated);
  if (result.isOk) {
    state.currentGame = updated;
    state.playerRole = 'p2';
    state.view = 'placing';
    resetShips();
    try { state.questions = normalizeQuestions(JSON.parse(game.questionsJson)); } catch {}
    render();
  } else {
    toast('Připojení se nepodařilo.', 'error');
  }
}

async function setReady() {
  if (!allShipsPlaced()) { toast('Nejdřív rozmísti všechny lodě.', 'error'); return; }

  const game = state.currentGame;
  const updated = { ...game };

  if (state.playerRole === 'p1') {
    updated.player1Board = JSON.stringify(state.myBoard);
    updated.player1Ready = true;
  } else {
    updated.player2Board = JSON.stringify(state.myBoard);
    updated.player2Ready = true;
  }

  if (updated.player1Ready && updated.player2Ready) {
    updated.status = 'playing';
    updated.currentTurn = Math.random() < .5 ? 'p1' : 'p2';
    updated.currentQuestion = pickRandomQuestion();
    updated.shotsRemaining = 0;
  }

  const result = await store.update(updated);
  if (result.isOk) {
    state.currentGame = updated;
    if (updated.status === 'playing') state.view = 'playing';
    render();
  } else {
    toast('Stav se nepodařilo uložit.', 'error');
  }
}

function pickRandomQuestion() {
  const pool = state.questions.length ? state.questions : normalizeQuestions(DEFAULT_QUESTIONS);
  let q = pool[Math.floor(Math.random() * pool.length)];

  if (pool.length > 3) {
    for (let i = 0; i < 12 && state.lastQuestionIds.includes(String(q.id)); i++) {
      q = pool[Math.floor(Math.random() * pool.length)];
    }
    state.lastQuestionIds.push(String(q.id));
    if (state.lastQuestionIds.length > Math.min(6, pool.length - 1)) state.lastQuestionIds.shift();
  }

  return JSON.stringify(q);
}

async function answerQuestion(answerKey) {
  const game = state.currentGame;
  let q;
  try { q = JSON.parse(game.currentQuestion); }
  catch { return; }

  const chosen = asStringKey(answerKey);
  const correctKey = asStringKey(q.spravna_odpoved);
  const correct = chosen === correctKey;

  state.questionAnswered = true;

  document.querySelectorAll('[data-answer]').forEach(btn => {
    btn.disabled = true;
    const key = asStringKey(btn.dataset.answer);
    if (key === correctKey) btn.classList.add('answer-correct');
    else if (key === chosen && !correct) btn.classList.add('answer-wrong');
  });

  await new Promise(r => setTimeout(r, 900));

  const updated = { ...game, shotsRemaining: correct ? 2 : 1, currentQuestion: '', lastAction: `${state.playerRole} answered ${correct ? 'correct' : 'wrong'}` };
  const result = await store.update(updated);

  if (result.isOk) {
    state.currentGame = updated;
    state.questionAnswered = false;
    toast(correct ? 'Správně! Máš 2 výstřely.' : 'Špatně. Máš 1 výstřel.', correct ? 'success' : 'error');
    render();
  } else {
    toast('Odpověď se nepodařilo uložit.', 'error');
  }
}

async function fireShot(x, y) {
  const game = state.currentGame;
  if (!game || game.currentTurn !== state.playerRole) return;
  if (game.shotsRemaining <= 0) { toast('Nejdřív odpověz na otázku.', 'info'); return; }

  const myShotsStr = state.playerRole === 'p1' ? game.player1Shots : game.player2Shots;
  const oppBoardStr = state.playerRole === 'p1' ? game.player2Board : game.player1Board;

  let myShots, oppBoard;
  try {
    myShots = JSON.parse(myShotsStr);
    oppBoard = JSON.parse(oppBoardStr);
  } catch {
    toast('Chyba dat hry.', 'error');
    return;
  }

  if (myShots[y][x] !== 0) { toast('Na toto pole už jsi střílel.', 'error'); return; }

  const hit = oppBoard[y][x] === 1;
  myShots[y][x] = hit ? 3 : 2;

  if (hit) {
    const sunkCells = checkSunkShip(x, y, oppBoard, myShots);
    if (sunkCells) {
      sunkCells.forEach(([cx, cy]) => myShots[cy][cx] = 4);
      toast('Loď potopena! 🔥', 'success');
    } else {
      toast('Zásah! 💥', 'success');
    }
  } else {
    toast('Vedle… 💦', 'info');
  }

  const updated = { ...game };
  if (state.playerRole === 'p1') {
    updated.player1Shots = JSON.stringify(myShots);
    updated.player1Score = (game.player1Score || 0) + (hit ? 1 : 0);
  } else {
    updated.player2Shots = JSON.stringify(myShots);
    updated.player2Score = (game.player2Score || 0) + (hit ? 1 : 0);
  }

  updated.shotsRemaining = game.shotsRemaining - 1;

  const allShipCells = [];
  for (let yy = 0; yy < BOARD_SIZE; yy++) {
    for (let xx = 0; xx < BOARD_SIZE; xx++) {
      if (oppBoard[yy][xx] === 1) allShipCells.push([xx, yy]);
    }
  }
  const allHit = allShipCells.length > 0 && allShipCells.every(([cx, cy]) => myShots[cy][cx] === 3 || myShots[cy][cx] === 4);

  if (allHit) {
    updated.status = 'finished';
    updated.winner = state.playerRole;
  } else if (updated.shotsRemaining <= 0) {
    updated.currentTurn = state.playerRole === 'p1' ? 'p2' : 'p1';
    updated.currentQuestion = pickRandomQuestion();
  }

  const result = await store.update(updated);
  if (result.isOk) {
    state.currentGame = updated;
    if (updated.status === 'finished') state.view = 'gameover';
    render();
  } else {
    toast('Výstřel se nepodařilo uložit.', 'error');
  }
}

function checkSunkShip(hitX, hitY, oppBoard, shots) {
  const visited = new Set();
  const stack = [[hitX, hitY]];
  const shipCells = [];

  while (stack.length) {
    const [x, y] = stack.pop();
    const key = `${x},${y}`;
    if (visited.has(key)) continue;
    if (x < 0 || x >= BOARD_SIZE || y < 0 || y >= BOARD_SIZE) continue;
    if (oppBoard[y][x] !== 1) continue;
    visited.add(key);
    shipCells.push([x, y]);
    stack.push([x + 1, y], [x - 1, y], [x, y + 1], [x, y - 1]);
  }

  return shipCells.every(([x, y]) => shots[y][x] === 3 || shots[y][x] === 4) ? shipCells : null;
}

function getOpponentShotsView() {
  const game = state.currentGame;
  const shotsStr = state.playerRole === 'p1' ? game.player1Shots : game.player2Shots;
  try { return JSON.parse(shotsStr); } catch { return createEmptyBoard(); }
}

function getMyBoardWithShots() {
  const game = state.currentGame;
  const myBoardStr = state.playerRole === 'p1' ? game.player1Board : game.player2Board;
  const oppShotsStr = state.playerRole === 'p1' ? game.player2Shots : game.player1Shots;

  let myBoard = createEmptyBoard();
  let oppShots = createEmptyBoard();
  try { myBoard = JSON.parse(myBoardStr); } catch {}
  try { oppShots = JSON.parse(oppShotsStr); } catch {}

  const merged = createEmptyBoard();
  for (let y = 0; y < BOARD_SIZE; y++) {
    for (let x = 0; x < BOARD_SIZE; x++) {
      if (oppShots[y][x] === 2) merged[y][x] = 2;
      else if (oppShots[y][x] === 3) merged[y][x] = 3;
      else if (oppShots[y][x] === 4) merged[y][x] = 4;
      else if (myBoard[y][x] === 1) merged[y][x] = 1;
    }
  }
  return merged;
}

