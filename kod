/* ===================== BOARDS ===================== */

function allShipsPlaced() {
  return state.placedShips.length === SHIPS.reduce((s, sh) => s + sh.count, 0);
}

function canPlaceShip(x, y, size, orientation) {
  for (let i = 0; i < size; i++) {
    const cx = orientation === 'h' ? x + i : x;
    const cy = orientation === 'h' ? y : y + i;
    if (cx < 0 || cx >= BOARD_SIZE || cy < 0 || cy >= BOARD_SIZE) return false;

    for (let dy = -1; dy <= 1; dy++) {
      for (let dx = -1; dx <= 1; dx++) {
        const nx = cx + dx, ny = cy + dy;
        if (nx >= 0 && nx < BOARD_SIZE && ny >= 0 && ny < BOARD_SIZE && state.myBoard[ny][nx] === 1) return false;
      }
    }
  }
  return true;
}

function placeShip(x, y, size, orientation) {
  const cells = [];
  for (let i = 0; i < size; i++) {
    const cx = orientation === 'h' ? x + i : x;
    const cy = orientation === 'h' ? y : y + i;
    state.myBoard[cy][cx] = 1;
    cells.push([cx, cy]);
  }
  state.placedShips.push({ size, cells });
}

function resetShips() {
  state.myBoard = createEmptyBoard();
  state.placedShips = [];
  state.selectedShipSize = null;
}

function randomPlaceShips() {
  resetShips();
  for (const ship of SHIPS) {
    for (let n = 0; n < ship.count; n++) {
      let placed = false;
      for (let tries = 0; tries < 500 && !placed; tries++) {
        const orientation = Math.random() < .5 ? 'h' : 'v';
        const x = Math.floor(Math.random() * BOARD_SIZE);
        const y = Math.floor(Math.random() * BOARD_SIZE);
        if (canPlaceShip(x, y, ship.size, orientation)) {
          placeShip(x, y, ship.size, orientation);
          placed = true;
        }
      }
      if (!placed) {
        toast('Náhodné rozmístění se nepovedlo. Zkus to znovu.', 'error');
        resetShips();
        return;
      }
    }
  }
}

