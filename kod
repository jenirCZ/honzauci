    .cell-sunk {
      background: linear-gradient(135deg, #7c2d12, #450a0a);
      border-color: #dc2626;
    }
    .coord-label {
      font-size: 10px;
      font-family: 'JetBrains Mono', monospace;
      color: rgba(125, 211, 252, .45);
      pointer-events: none;
      position: absolute;
      top: 2px;
      left: 4px;
    }

    .ship-tile {
      background: rgba(6, 182, 212, .15);
      border: 1px solid rgba(6, 182, 212, .42);
      border-radius: 12px;
      padding: 10px 7px;
      cursor: pointer;
      transition: all .2s;
