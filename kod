  const btnHostTestJson = document.getElementById('btn-host-test-json');
  if (btnHostTestJson) btnHostTestJson.onclick = () => {
    const resultEl = document.getElementById('json-result');
    try {
      const qs = normalizeQuestions(JSON.parse(document.getElementById('questions-json-paste')?.value || ''));
      resultEl.innerHTML = prettyQuestionResult(qs);
      safeIcons();
    } catch (e) {
      resultEl.innerHTML = `<div class="p-3 rounded-xl bg-red-500/15 border border-red-500/30 text-xs text-red-300">${escapeHtml(e.message)}</div>`;
    }
  };

  const btnCreate = document.getElementById('btn-create-game');
  if (btnCreate) btnCreate.onclick = createGame;

  const codeInput = document.getElementById('game-code-input');
  if (codeInput) codeInput.oninput = e => e.target.value = e.target.value.replace(/\D/g, '').slice(0, 4);

  const btnJoinGame = document.getElementById('btn-join-game');
  if (btnJoinGame) btnJoinGame.onclick = joinGame;

  const btnCancel = document.getElementById('btn-cancel-game');
  if (btnCancel) btnCancel.onclick = cancelGame;

  const btnCopy = document.getElementById('btn-copy-code');
  if (btnCopy) btnCopy.onclick = () => {
    const code = state.currentGame?.gameCode || '';
    if (navigator.clipboard) navigator.clipboard.writeText(code).then(() => toast('Kód zkopírován.', 'success'));
    else toast(`Kód hry: ${code}`, 'info');
  };

  document.querySelectorAll('[data-ship-size]').forEach(btn => {
    btn.onclick = () => {
      const size = Number(btn.dataset.shipSize);
      state.selectedShipSize = state.selectedShipSize === size ? null : size;
      render();
    };
  });

  const btnOri = document.getElementById('btn-orientation');
  if (btnOri) btnOri.onclick = () => {
    state.shipOrientation = state.shipOrientation === 'h' ? 'v' : 'h';
    render();
  };

  const btnReset = document.getElementById('btn-reset-ships');
  if (btnReset) btnReset.onclick = () => { resetShips(); render(); };

  const btnRandom = document.getElementById('btn-random-ships');
  if (btnRandom) btnRandom.onclick = () => { randomPlaceShips(); render(); };

  const btnReady = document.getElementById('btn-ready');
  if (btnReady) btnReady.onclick = setReady;

  document.querySelectorAll('[data-mode="place"]').forEach(cell => {
    cell.onclick = () => {
      if (!state.selectedShipSize) { toast('Nejdřív vyber loď.', 'info'); return; }
      const x = Number(cell.dataset.x), y = Number(cell.dataset.y);
      if (!canPlaceShip(x, y, state.selectedShipSize, state.shipOrientation)) {
        toast('Sem loď umístit nelze.', 'error');
        return;
      }
      const size = state.selectedShipSize;
      placeShip(x, y, size, state.shipOrientation);
      const placed = state.placedShips.filter(s => s.size === size).length;
      const max = SHIPS.find(s => s.size === size).count;
      if (placed >= max) state.selectedShipSize = null;
      render();
    };

    cell.onmouseenter = () => {
      if (!state.selectedShipSize) return;
      const x = Number(cell.dataset.x), y = Number(cell.dataset.y);
      const valid = canPlaceShip(x, y, state.selectedShipSize, state.shipOrientation);
      const cls = valid ? 'cell-ship-preview' : 'cell-ship-invalid';
      for (let i = 0; i < state.selectedShipSize; i++) {
        const cx = state.shipOrientation === 'h' ? x + i : x;
        const cy = state.shipOrientation === 'h' ? y : y + i;
        const target = document.querySelector(`[data-mode="place"][data-x="${cx}"][data-y="${cy}"]`);
        if (target && !target.classList.contains('cell-ship')) target.classList.add(cls);
      }
    };

    cell.onmouseleave = () => {
      document.querySelectorAll('.cell-ship-preview,.cell-ship-invalid').forEach(el => el.classList.remove('cell-ship-preview', 'cell-ship-invalid'));
    };
  });

  document.querySelectorAll('[data-mode="shoot"]').forEach(cell => {
    cell.onclick = () => fireShot(Number(cell.dataset.x), Number(cell.dataset.y));
  });

  document.querySelectorAll('[data-answer]').forEach(btn => {
    // DŮLEŽITÉ: odpověď je písmeno a/b/c/d, NE parseInt().
    btn.onclick = () => answerQuestion(btn.dataset.answer);
  });

  const btnBackMenu = document.getElementById('btn-back-menu');
  if (btnBackMenu) btnBackMenu.onclick = () => { resetState(); render(); };

  const btnLogin = document.getElementById('btn-admin-login');
  if (btnLogin) btnLogin.onclick = adminLogin;

  const passInput = document.getElementById('admin-password');
  if (passInput) passInput.onkeydown = e => { if (e.key === 'Enter') adminLogin(); };

  const btnLogout = document.getElementById('btn-logout');
  if (btnLogout) btnLogout.onclick = () => {
    state.adminAuthenticated = false;
    state.view = 'menu';
    render();
  };

  document.querySelectorAll('[data-tab]').forEach(tab => {
    tab.onclick = () => {
      state.activeAdminTab = tab.dataset.tab;
      render();
    };
  });

  const btnCreateTopic = document.getElementById('btn-create-topic');
  if (btnCreateTopic) btnCreateTopic.onclick = createTopicFromUrl;

  document.querySelectorAll('[data-topic-id]').forEach(btn => {
    btn.onclick = async () => {
      const topic = state.allTopics.find(t => t.__backendId === btn.dataset.topicId);
      if (!topic) return;
      const result = await store.delete(topic);
      if (result.isOk) {
        toast(`Okruh „${topic.topicName}“ smazán.`, 'success');
        render();
      } else {
        toast('Okruh se nepodařilo smazat.', 'error');
      }
    };
  });

  const btnTestUrl = document.getElementById('btn-test-url');
  if (btnTestUrl) btnTestUrl.onclick = async () => {
    const resultEl = document.getElementById('admin-result');
    resultEl.innerHTML = '<div class="flex items-center gap-2 text-cyan-300"><div class="loader" style="width:14px;height:14px"></div>Načítám…</div>';
    try {
      const qs = await loadQuestionsFromUrl(document.getElementById('admin-url')?.value);
      resultEl.innerHTML = prettyQuestionResult(qs);
      safeIcons();
    } catch (e) {
      resultEl.innerHTML = `<div class="p-3 rounded-xl bg-red-500/15 border border-red-500/30 text-xs text-red-300">${escapeHtml(e.message)}</div>`;
    }
  };

  const btnValidate = document.getElementById('btn-validate-json');
  if (btnValidate) btnValidate.onclick = () => {
    const resultEl = document.getElementById('admin-json-result');
    try {
      const qs = normalizeQuestions(JSON.parse(document.getElementById('admin-json-paste')?.value || ''));
      resultEl.innerHTML = prettyQuestionResult(qs);
      safeIcons();
    } catch (e) {
      resultEl.innerHTML = `<div class="p-3 rounded-xl bg-red-500/15 border border-red-500/30 text-xs text-red-300">${escapeHtml(e.message)}</div>`;
    }
  };
}


function updateTopicSelectionSummary() {
  const el = document.getElementById('topic-selection-summary');
  if (!el) return;
  const ids = Array.from(document.querySelectorAll('.topic-choice:checked')).map(ch => ch.value);
  const selected = state.allTopics.filter(t => ids.includes(t.__backendId));
  const count = selected.reduce((sum, t) => sum + Number(t.questionCount || 0), 0);
  el.textContent = ids.length
    ? `Vybráno: ${ids.length} okruhů · přibližně ${count} otázek.`
    : 'Není vybraný žádný okruh.';
}

function adminLogin() {
  const pass = document.getElementById('admin-password')?.value;
  if (pass === '579') {
    state.adminAuthenticated = true;
    state.activeAdminTab = 'topics';
    render();
  } else {
    toast('Nesprávné heslo.', 'error');
    const inp = document.getElementById('admin-password');
    if (inp) inp.value = '';
  }
}

init();
</script>
</body>
</html>
