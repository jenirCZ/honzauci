      .coord-label { display: none; }
    }
  </style>
</head>

<body class="h-full ocean-bg">
  <main id="app" class="grid-pattern"></main>

<script>
/* ============================================================
   BATTLE QUIZ – LODĚ PRO ZŠ
   Kompletně přepracovaná verze:
   - funguje v Canvě s dataSdk
   - funguje i mimo Canvu v lokálním režimu přes localStorage
   - robustní načítání JSON z GitHub raw URL
   - opravené odpovědi a/b/c/d
   - učitelský režim, tester JSON, vlastní okruhy
   ============================================================ */

const DEFAULT_QUESTIONS_URL = 'https://raw.githubusercontent.com/jenirCZ/honzauci/refs/heads/main/Hustota%202';

const DEFAULT_QUESTIONS = [
  { id: 1, otazka: "Kterým písmenem řecké abecedy obvykle značíme hustotu?", moznosti: { a: "ρ (ró)", b: "σ (sigma)", c: "ω (omega)", d: "δ (delta)" }, spravna_odpoved: "a" },
  { id: 2, otazka: "Jak zní základní vzorec pro výpočet hustoty?", moznosti: { a: "ρ = m · V", b: "ρ = m / V", c: "ρ = V / m", d: "ρ = m + V" }, spravna_odpoved: "b" },
  { id: 3, otazka: "Jaká je základní jednotka hustoty v SI?", moznosti: { a: "kg/m³", b: "g/cm", c: "N/kg", d: "m³/kg" }, spravna_odpoved: "a" },
  { id: 4, otazka: "Co znamená, že má látka velkou hustotu?", moznosti: { a: "Má velký objem a malou hmotnost", b: "Na malý objem připadá velká hmotnost", c: "Vždy plave na vodě", d: "Je vždy kapalná" }, spravna_odpoved: "b" }
];

const BOARD_SIZE = 8;
const SHIPS = [
  { size: 4, count: 1, name: "Bitevní loď" },
  { size: 3, count: 2, name: "Křižník" },
  { size: 2, count: 3, name: "Torpédovka" },
  { size: 1, count: 4, name: "Ponorka" }
];

const app = document.getElementById('app');

const state = {
  view: 'menu',
  playerName: '',
  playerRole: null,
  currentGame: null,
  allRecords: [],
  allGames: [],
  allTopics: [],
  myBoard: createEmptyBoard(),
  placedShips: [],
  selectedShipSize: null,
  shipOrientation: 'h',
  questions: normalizeQuestions(DEFAULT_QUESTIONS),
  questionAnswered: false,
  adminAuthenticated: false,
  activeAdminTab: 'topics',
  storageMode: 'local',
  lastQuestionIds: []
};

const defaultConfig = {
  app_title: "BATTLE QUIZ",
  app_subtitle: "Lodě · Otázky · Souboj"
};

function createEmptyBoard() {
  return Array.from({ length: BOARD_SIZE }, () => Array(BOARD_SIZE).fill(0));
}

function escapeHtml(s) {
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function toast(msg, type = 'info') {
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2800);
}

function safeIcons() {
  if (window.lucide) lucide.createIcons();
}

function generateId() {
  return 'id_' + Math.random().toString(36).slice(2) + Date.now().toString(36);
}

function generateGameCode() {
  return Math.floor(1000 + Math.random() * 9000).toString();
}

function asStringKey(k) {
  return String(k ?? '').trim().toLowerCase();
}

/* ===================== JSON LOADER + VALIDATION ===================== */

function normalizeQuestions(raw) {
  if (!Array.isArray(raw)) throw new Error('JSON musí být pole otázek.');
  if (raw.length === 0) throw new Error('JSON neobsahuje žádné otázky.');

  return raw.map((q, index) => {
    if (!q || typeof q !== 'object') throw new Error(`Otázka ${index + 1} není objekt.`);
    const text = q.otazka ?? q.question ?? q.text;
    const options = q.moznosti ?? q.options ?? q.answers;
    const correct = q.spravna_odpoved ?? q.correct ?? q.answer;

    if (!text || typeof text !== 'string') throw new Error(`Otázka ${index + 1} nemá text "otazka".`);
    if (!options || typeof options !== 'object' || Array.isArray(options)) throw new Error(`Otázka ${index + 1} nemá objekt "moznosti".`);

    const keys = ['a', 'b', 'c', 'd'];
    const normalizedOptions = {};
    for (const k of keys) {
      if (options[k] == null || String(options[k]).trim() === '') {
        throw new Error(`Otázka ${index + 1} nemá možnost "${k}".`);
      }
      normalizedOptions[k] = String(options[k]);
    }

    const correctKey = asStringKey(correct);
    if (!keys.includes(correctKey)) {
      throw new Error(`Otázka ${index + 1} má špatnou hodnotu "spravna_odpoved". Musí být a, b, c nebo d.`);
    }

    return {
      id: q.id ?? index + 1,
      otazka: text.trim(),
      moznosti: normalizedOptions,
      spravna_odpoved: correctKey
    };
  });
}

async function loadQuestionsFromUrl(url) {
  const cleanUrl = String(url || '').trim();
  if (!cleanUrl) throw new Error('Zadej URL adresu.');
  if (!/^https?:\/\//i.test(cleanUrl)) throw new Error('URL musí začínat http:// nebo https://.');

  const res = await fetch(cleanUrl, { cache: 'no-store' });
  if (!res.ok) throw new Error(`URL se nepodařilo načíst. HTTP ${res.status}.`);

  const text = await res.text();
  let data;
  try {
    data = JSON.parse(text);
  } catch (e) {
    throw new Error('Soubor není platný JSON. Zkontroluj, že na URL není HTML stránka, ale raw JSON.');
  }
  return normalizeQuestions(data);
}

function prettyQuestionResult(questions) {
  return `
    <div class="p-3 rounded-xl bg-green-500/15 border border-green-500/30">
      <div class="flex items-center gap-2 text-green-300 text-sm font-bold mb-2">
        <i data-lucide="check-circle" class="w-4 h-4"></i> JSON je v pořádku
      </div>
      <p class="text-xs text-green-100/80">Načteno <strong>${questions.length}</strong> otázek.</p>
      <p class="text-xs text-green-100/80 mt-1">Ukázka: „${escapeHtml(questions[0].otazka)}“</p>
    </div>
  `;
}

/* ===================== STORAGE LAYER ===================== */

const localStore = {
  key: 'battle_quiz_lode_records_v2',
  read() {
    try { return JSON.parse(localStorage.getItem(this.key) || '[]'); }
    catch { return []; }
  },
  write(records) {
    localStorage.setItem(this.key, JSON.stringify(records));
    receiveData(records);
  },
  async create(record) {
    const records = this.read();
    const stored = { ...record, __backendId: generateId() };
    records.push(stored);
    this.write(records);
    return { isOk: true, record: stored };
  },
  async update(record) {
    const records = this.read();
    const id = record.__backendId;
    const idx = records.findIndex(r => r.__backendId === id);
    if (idx < 0) return { isOk: false };
    records[idx] = { ...record };
    this.write(records);
    return { isOk: true };
  },
  async delete(record) {
    const records = this.read().filter(r => r.__backendId !== record.__backendId);
    this.write(records);
    return { isOk: true };
  }
};

const store = {
  async create(record) {
    if (window.dataSdk) return await window.dataSdk.create(record);
    return await localStore.create(record);
  },
  async update(record) {
    if (window.dataSdk) return await window.dataSdk.update(record);
    return await localStore.update(record);
  },
  async delete(record) {
    if (window.dataSdk) return await window.dataSdk.delete(record);
    return await localStore.delete(record);
  }
};

function receiveData(data) {
  state.allRecords = Array.isArray(data) ? data : [];
  state.allGames = state.allRecords.filter(r => r.type === 'game' || !r.type);
  state.allTopics = state.allRecords.filter(r => r.type === 'topic');

  if (state.currentGame) {
    const updated = state.allGames.find(g => g.__backendId === state.currentGame.__backendId);
    if (updated) {
      // DŮLEŽITÉ:
      // Původní verze překreslovala obrazovku i tehdy, když se data vůbec nezměnila.
      // Na obrazovce s čtyřmístným kódem to způsobovalo opakované spouštění animace.
      const oldSnapshot = JSON.stringify(state.currentGame);
      const newSnapshot = JSON.stringify(updated);
      if (oldSnapshot === newSnapshot) return;

      const oldStatus = state.currentGame.status;
      const oldTurn = state.currentGame.currentTurn;
      const oldQuestion = state.currentGame.currentQuestion;
      state.currentGame = updated;

      if (updated.questionsJson) {
        try { state.questions = normalizeQuestions(JSON.parse(updated.questionsJson)); }
        catch {}
      }

      if (updated.status === 'finished') {
        state.view = 'gameover';
        render();
      } else if (oldStatus !== updated.status || oldTurn !== updated.currentTurn || oldQuestion !== updated.currentQuestion || ['waiting','placing','playing','admin'].includes(state.view)) {
        if (updated.status === 'placing') state.view = 'placing';
        if (updated.status === 'playing') state.view = 'playing';
        render();
      }
    }
  }
}

async function init() {
  if (window.elementSdk) {
    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (config) => {
        document.querySelectorAll('[data-bind="app_title"]').forEach(el => el.textContent = config.app_title || defaultConfig.app_title);
        document.querySelectorAll('[data-bind="app_subtitle"]').forEach(el => el.textContent = config.app_subtitle || defaultConfig.app_subtitle);
      },
      mapToCapabilities: () => ({ recolorables: [], borderables: [], fontEditable: undefined, fontSizeable: undefined }),
      mapToEditPanelValues: (config) => new Map([
        ["app_title", config.app_title || defaultConfig.app_title],
        ["app_subtitle", config.app_subtitle || defaultConfig.app_subtitle]
      ])
    });
  }

  if (window.dataSdk) {
    state.storageMode = 'canva';
    await window.dataSdk.init({ onDataChanged: receiveData });
  } else {
    state.storageMode = 'local';
    receiveData(localStore.read());
    window.addEventListener('storage', () => receiveData(localStore.read()));
    setInterval(() => receiveData(localStore.read()), 1000);
  }

  render();
}

/* ===================== RENDERING ===================== */

function render() {
  const views = {
    menu: renderMenu,
    host: renderHost,
    join: renderJoin,
    waiting: renderWaiting,
    placing: renderPlacing,
    playing: renderPlaying,
    gameover: renderGameOver,
    admin: renderAdmin
  };
  app.innerHTML = (views[state.view] || renderMenu)();
  safeIcons();
  attachListeners();
}

function renderShell(content, classes = 'p-5') {
  return `<div class="min-h-full ${classes} slide-up">${content}</div>`;
}

function renderMenu() {
  return renderShell(`
    <div class="min-h-full flex flex-col items-center justify-center">
      <div class="w-full max-w-md">
        <div class="text-center mb-9 float-anim">
          <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl mb-4 glow-cyan"
               style="background: linear-gradient(135deg, #06b6d4, #7c3aed);">
            <i data-lucide="anchor" class="w-12 h-12 text-white"></i>
          </div>
          <h1 data-bind="app_title" class="text-4xl font-bold tracking-tight mb-1"
              style="background: linear-gradient(135deg, #22d3ee, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            ${defaultConfig.app_title}
          </h1>
          <p data-bind="app_subtitle" class="text-sm text-cyan-300/70 font-mono uppercase tracking-widest">${defaultConfig.app_subtitle}</p>
        </div>

        <div class="card-glass p-5 mb-4">
          <label class="text-xs uppercase tracking-widest text-cyan-300/60 font-mono mb-2 block">Jméno hráče / týmu</label>
          <input id="player-name" class="input-field" placeholder="Např. Tým Archimédes" value="${escapeHtml(state.playerName)}" maxlength="24" />
        </div>

