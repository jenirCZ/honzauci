<!doctype html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Fyzikální ptáček</title>
  <style>
    :root{--bg:#70c5ce;--ground:#ded895;--pipe:#5dbb63;--text:#1b2430}
    body{margin:0;font-family:Arial,sans-serif;background:#0f172a;color:#e2e8f0;display:flex;justify-content:center}
    .wrap{max-width:1000px;width:100%;padding:16px}
    .panel{background:#1e293b;border-radius:12px;padding:12px;margin-bottom:12px}
    input,select,button{padding:8px;border-radius:8px;border:1px solid #475569;background:#0f172a;color:#e2e8f0}
    button{cursor:pointer}
    .row{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    canvas{background:var(--bg);display:block;width:100%;max-width:480px;height:auto;border-radius:12px;border:3px solid #334155}
    .hidden{display:none}
    label{margin-right:8px}
    .qbox{font-size:1.1rem}
    .ok{color:#22c55e}.bad{color:#ef4444}
  </style>
</head>
<body>
<div class="wrap">
  <h1>🐦 Fyzikální ptáček</h1>
  <div class="panel" id="setup">
    <div class="row">
      <label>Jméno ptáčka: <input id="birdName" value="Newton" maxlength="20"></label>
    </div>
    <p>Vyber okruhy převodů (lze kombinovat):</p>
    <div class="row" id="topics"></div>
    <button id="startBtn">Spustit hru</button>
  </div>

  <div class="row hidden" id="gameArea">
    <canvas id="game" width="480" height="640"></canvas>
    <div class="panel" style="flex:1;min-width:250px">
      <h3 id="birdLabel"></h3>
      <p>Skóre: <b id="score">0</b> | Nejlepší: <b id="best">0</b></p>
      <div class="qbox" id="question">Připrav se na první překážku…</div>
      <div class="row" style="margin-top:8px">
        <input id="answer" placeholder="zadej přesný výsledek" />
        <button id="checkBtn">Odeslat</button>
      </div>
      <p id="feedback"></p>
      <p>Ovládání: mezerník / klik = skok.</p>
      <button id="restartBtn" class="hidden">Hrát znovu</button>
    </div>
  </div>
</div>
<script>
const TOPICS={
  delka:{label:'Délka',units:['mm','cm','dm','m','km']},
  hmotnost:{label:'Hmotnost',units:['mg','g','kg','t']},
  cas:{label:'Čas',units:['s','min','h']},
  objem:{label:'Objem',units:['ml','cl','dl','l']},
  obsah:{label:'Obsah',units:['mm²','cm²','dm²','m²']}
};
const factors={mm:1,cm:10,dm:100,m:1000,km:1000000,mg:1,g:1000,kg:1000000,t:1000000000,s:1,min:60,h:3600,ml:1,cl:10,dl:100,l:1000,'mm²':1,'cm²':100,'dm²':10000,'m²':1000000};
const topicWrap=document.getElementById('topics');
Object.entries(TOPICS).forEach(([k,v])=>{topicWrap.insertAdjacentHTML('beforeend',`<label><input type="checkbox" value="${k}" checked> ${v.label}</label>`)});

const c=document.getElementById('game'),ctx=c.getContext('2d');
let bird,pipes,vy,score,best=0,alive=false,lastPipe=0,qLocked=false,currentQ=null;
const G=0.45,J=-7.2,pipeGap=170,pipeW=64,speed=2.6;
function reset(){bird={x:120,y:280,r:15};pipes=[];vy=0;score=0;alive=true;lastPipe=0;qLocked=false;currentQ=null;setQ('Leť a připrav se na úlohu.');upd();document.getElementById('feedback').textContent='';document.getElementById('restartBtn').classList.add('hidden')}
function selTopics(){return [...document.querySelectorAll('#topics input:checked')].map(x=>x.value)}
function randInt(a,b){return Math.floor(Math.random()*(b-a+1))+a}
function pick(arr){return arr[Math.floor(Math.random()*arr.length)]}
function genQuestion(){
  const active=selTopics();
  const t=TOPICS[pick(active)];
  let u1=pick(t.units),u2=pick(t.units); while(u1===u2)u2=pick(t.units);
  const f=factors[u2]/factors[u1];
  let base;
  const safe=[2,4,5,8,10,12,15,20,24,25,30,40,50,60,75,80,100,120,125,150,200,240,250,300,400,500,600,750,800,900];
  base=pick(safe);
  const ans=(base*f).toString();
  return {text:`Převeď: ${base} ${u1} = ? ${u2}`,ans};
}
function setQ(t){document.getElementById('question').textContent=t}
function upd(){scoreEl.textContent=score;bestEl.textContent=best}
const scoreEl=document.getElementById('score'),bestEl=document.getElementById('best');

function spawn(){const top=randInt(80,420);pipes.push({x:480,top,asked:false,passed:false})}
function jump(){if(alive){vy=J}}
window.addEventListener('keydown',e=>{if(e.code==='Space'){e.preventDefault();jump();}});
c.addEventListener('click',jump);

function loop(ts){
  if(!alive){draw();return requestAnimationFrame(loop)}
  if(ts-lastPipe>1450){spawn();lastPipe=ts}
  vy+=G; bird.y+=vy;
  pipes.forEach(p=>p.x-=speed);
  pipes=pipes.filter(p=>p.x+pipeW>-5);

  for(const p of pipes){
    if(!p.asked && p.x<bird.x+70){currentQ=genQuestion();setQ(currentQ.text);qLocked=true;p.asked=true;}
    const hitX=bird.x+bird.r>p.x&&bird.x-bird.r<p.x+pipeW;
    const hitY=bird.y-bird.r<p.top||bird.y+bird.r>p.top+pipeGap;
    if(hitX&&hitY){gameOver('Narazil jsi do trubky.');}
    if(!p.passed&&p.x+pipeW<bird.x){p.passed=true;score++;best=Math.max(best,score);upd();}
  }
  if(bird.y>610||bird.y<0)gameOver('Ptáček vylétl mimo prostor.');
  draw();requestAnimationFrame(loop)
}

function draw(){
  ctx.clearRect(0,0,480,640);
  ctx.fillStyle='#86efac';ctx.fillRect(0,560,480,80);
  ctx.fillStyle='#5dbb63';
  for(const p of pipes){ctx.fillRect(p.x,0,pipeW,p.top);ctx.fillRect(p.x,p.top+pipeGap,pipeW,640-(p.top+pipeGap));}
  ctx.save();ctx.translate(bird.x,bird.y);ctx.rotate(Math.max(-0.4,Math.min(0.8,vy/10)));
  ctx.fillStyle='#facc15';ctx.beginPath();ctx.arc(0,0,bird.r,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#000';ctx.beginPath();ctx.arc(5,-4,2.5,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#f97316';ctx.fillRect(12,-2,8,5);ctx.restore();
  ctx.fillStyle='#111827';ctx.font='bold 28px Arial';ctx.fillText(score,230,50);
}

function gameOver(msg){alive=false;document.getElementById('feedback').innerHTML=`<span class='bad'>${msg}</span>`;document.getElementById('restartBtn').classList.remove('hidden')}

document.getElementById('checkBtn').onclick=()=>{
  if(!qLocked||!currentQ)return;
  const val=document.getElementById('answer').value.trim().replace(',','.');
  if(val===currentQ.ans){document.getElementById('feedback').innerHTML="<span class='ok'>Správně ✅</span>";qLocked=false;document.getElementById('answer').value='';setQ('Správně! Pokračuj v letu.');}
  else{document.getElementById('feedback').innerHTML=`<span class='bad'>Špatně. Správně: ${currentQ.ans}</span>`;gameOver('Chybný převod zastavil let.');}
}

document.getElementById('startBtn').onclick=()=>{
  if(selTopics().length===0){alert('Vyber alespoň jeden okruh.');return;}
  document.getElementById('birdLabel').textContent='Ptáček: '+(document.getElementById('birdName').value||'Newton');
  document.getElementById('setup').classList.add('hidden');
  document.getElementById('gameArea').classList.remove('hidden');
  reset();requestAnimationFrame(loop);
}
document.getElementById('restartBtn').onclick=()=>reset();
</script>
</body>
</html>
