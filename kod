function renderShipsPalette() {
  const placed = {};
  state.placedShips.forEach(s => placed[s.size] = (placed[s.size] || 0) + 1);

  return SHIPS.map(ship => {
    const usedCount = placed[ship.size] || 0;
    const remaining = ship.count - usedCount;
    const disabled = remaining <= 0;
    const selected = state.selectedShipSize === ship.size && !disabled;
    return `
      <button data-ship-size="${ship.size}" class="ship-tile ${selected ? 'selected' : ''} ${disabled ? 'placed' : ''}" ${disabled ? 'disabled' : ''}>
        <div class="flex gap-0.5 justify-center mb-1">
          ${Array.from({ length: ship.size }, () => '<div class="ship-block" style="width:10px;height:10px"></div>').join('')}
        </div>
        <div class="text-[11px] font-mono text-center text-cyan-200/80">${remaining}/${ship.count}</div>
        <div class="text-[10px] text-center text-cyan-100/40 truncate">${ship.name}</div>
      </button>
    `;
  }).join('');
}

function renderBoard(board, mode, coords = false) {
  let html = '';
  for (let y = 0; y < BOARD_SIZE; y++) {
    for (let x = 0; x < BOARD_SIZE; x++) {
      const v = board[y][x];
      let cls = 'cell';
      let content = coords ? `<span class="coord-label">${String.fromCharCode(65 + x)}${y + 1}</span>` : '';
      let disabled = '';

      if (mode === 'place') {
        if (v === 1) cls += ' cell-ship';
      } else if (mode === 'shoot') {
        if (v === 2) { cls += ' cell-miss'; disabled = 'disabled'; }
        else if (v === 3) { cls += ' cell-hit'; disabled = 'disabled'; content += '<i data-lucide="flame" class="w-4 h-4 text-yellow-200"></i>'; }
        else if (v === 4) { cls += ' cell-sunk'; disabled = 'disabled'; content += '<i data-lucide="x" class="w-4 h-4 text-white"></i>'; }
      } else if (mode === 'own') {
        if (v === 1) cls += ' cell-ship';
        else if (v === 2) cls += ' cell-miss';
        else if (v === 3) { cls += ' cell-hit'; content += '<i data-lucide="flame" class="w-3 h-3 text-yellow-200"></i>'; }
        else if (v === 4) { cls += ' cell-sunk'; content += '<i data-lucide="x" class="w-3 h-3 text-white"></i>'; }
      }

      html += `<button class="${cls}" data-x="${x}" data-y="${y}" data-mode="${mode}" ${disabled}>${content}</button>`;
    }
  }
  return html;
}

