<!doctype html>
<html lang="cs" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>BATTLE QUIZ – Lodě pro ZŠ</title>

  <!-- Canva SDK: v Canvě funguje, mimo Canvu se bezpečně přeskočí -->
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>

  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

  <style>
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { height: 100%; }
    body {
      font-family: 'Space Grotesk', sans-serif;
      background: #0a0e27;
      color: #e4e8ff;
      overflow: hidden;
    }
    .font-mono { font-family: 'JetBrains Mono', monospace; }

    .ocean-bg {
      background:
        radial-gradient(ellipse at 20% 10%, rgba(56, 189, 248, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(168, 85, 247, 0.12) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(14, 165, 233, 0.08) 0%, transparent 70%),
        linear-gradient(180deg, #0a0e27 0%, #0f1638 50%, #0a0e27 100%);
    }
    .grid-pattern {
      background-image:
        linear-gradient(rgba(56, 189, 248, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(56, 189, 248, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    #app {
      height: 100dvh;
      width: 100%;
      overflow-y: auto;
      overflow-x: hidden;
      padding-bottom: max(12px, env(safe-area-inset-bottom));
    }

    .glow-cyan { box-shadow: 0 0 30px rgba(34, 211, 238, 0.4), 0 0 60px rgba(34, 211, 238, 0.2); }
    .glow-pink { box-shadow: 0 0 30px rgba(236, 72, 153, 0.4), 0 0 60px rgba(236, 72, 153, 0.2); }

    .card-glass {
      background: rgba(15, 23, 55, 0.62);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(56, 189, 248, 0.15);
      border-radius: 20px;
    }

    .input-field {
      background: rgba(15, 23, 55, 0.85);
      border: 1px solid rgba(56, 189, 248, 0.22);
      color: #e4e8ff;
      padding: 14px 18px;
      border-radius: 12px;
      width: 100%;
      font-size: 16px;
      transition: all .2s;
    }
    .input-field:focus {
      outline: none;
      border-color: #22d3ee;
      box-shadow: 0 0 0 3px rgba(34, 211, 238, .15);
    }
    textarea.input-field { min-height: 140px; resize: vertical; }

    .btn-primary {
      background: linear-gradient(135deg, #06b6d4, #0ea5e9);
      color: white;
      font-weight: 700;
      padding: 14px 22px;
      border-radius: 14px;
      transition: all .2s;
      box-shadow: 0 4px 20px rgba(6, 182, 212, .35);
    }
    .btn-primary:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(6, 182, 212, .55);
    }
    .btn-secondary {
      background: rgba(56, 189, 248, .1);
      border: 1px solid rgba(56, 189, 248, .3);
      color: #7dd3fc;
      font-weight: 600;
      padding: 12px 18px;
      border-radius: 12px;
      transition: all .2s;
    }
    .btn-secondary:hover:not(:disabled) {
      background: rgba(56, 189, 248, .2);
      border-color: rgba(56, 189, 248, .55);
    }
    .btn-danger {
      background: linear-gradient(135deg, #ec4899, #db2777);
      color: white;
      font-weight: 700;
      padding: 12px 18px;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(236, 72, 153, .35);
    }
    button:disabled { opacity: .45; cursor: not-allowed; }

    .cell {
      aspect-ratio: 1;
      min-width: 0;
      border: 1px solid rgba(56, 189, 248, .16);
      background: rgba(14, 165, 233, .045);
      transition: all .16s;
      position: relative;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      touch-action: manipulation;
    }
    .cell:hover:not(:disabled) {
      background: rgba(56, 189, 248, .15);
      border-color: rgba(56, 189, 248, .5);
      transform: scale(1.02);
    }
    .cell-ship {
      background: linear-gradient(135deg, #06b6d4, #0891b2);
      border-color: #22d3ee;
      box-shadow: inset 0 0 8px rgba(255,255,255,.22);
    }
    .cell-ship-preview {
      background: linear-gradient(135deg, rgba(6,182,212,.48), rgba(8,145,178,.48)) !important;
      border-color: #22d3ee !important;
    }
    .cell-ship-invalid {
      background: rgba(239,68,68,.32) !important;
      border-color: #ef4444 !important;
    }
    .cell-hit {
      background: radial-gradient(circle, #ef4444, #991b1b);
      border-color: #fca5a5;
      animation: hitPulse .55s ease-out;
    }
    .cell-miss {
      background: rgba(148,163,184,.22);
      border-color: rgba(148,163,184,.42);
    }
    .cell-miss::after {
      content: '';
      position: absolute;
      inset: 30%;
      background: rgba(148,163,184,.68);
      border-radius: 50%;
